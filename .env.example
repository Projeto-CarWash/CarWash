# Variáveis de ambiente do CarWash — copie para .env (e por ambiente: .env.dev, .env.hom, .env.prod)
# NUNCA versionar arquivos .env reais (DAT §8.3 — segredos fora do código)

# ---------- PostgreSQL ----------
POSTGRES_DB=carwash
POSTGRES_USER=carwash_owner
POSTGRES_PASSWORD=carwash123
POSTGRES_PORT=5432

# ---------- Backend (.NET) ----------
ASPNETCORE_ENVIRONMENT=Development
BACKEND_PORT=8080

# JWT — configuração de sessão (ADR 0002, RF001).
# .NET lê `Jwt__Secret` (double underscore) como `Jwt:Secret` no IConfiguration.
# Gere o secret com: openssl rand -base64 64  (mínimo 32 bytes para HMAC-SHA256).
Jwt__Issuer=carwash-api
Jwt__Audience=carwash-web
Jwt__Secret=trocar-em-cada-ambiente-com-pelo-menos-64-caracteres-aleatorios
Jwt__AccessTokenValiditySeconds=900
Jwt__RefreshTokenValiditySeconds=604800
# Chave HMAC dedicada ao token de confirmação de agendamento (RF015 / ADR 0004).
# DEVE ser distinta de Jwt__Secret. Gere com: openssl rand -base64 64 (mínimo 32 bytes).
Jwt__ConfirmacaoSigningKey=trocar-em-cada-ambiente-chave-dedicada-rf015-com-64-caracteres

# Origens permitidas pelo CORS (separar múltiplas com índices: __0, __1, ...).
# Frontend usa `withCredentials: true` — não pode usar `AllowAnyOrigin`.
Cors__AllowedOrigins__0=http://localhost:5173

# Senha do administrador inicial — obrigatória ao rodar a migration `InitialSchema` (DB001 §05 / decisão P12).
# Sem fallback: a migration falha com InvalidOperationException se ausente/vazia.
# Em dev: defina aqui. Em hom/prod: use secret manager do ambiente.
CARWASH_SEED_ADMIN_PASSWORD=TrocarEmCadaAmbiente!2026

# ---------- Frontend (Vite) ----------
# Em dev aponta para o backend direto; em hom/prod fica /api (passa pelo proxy)
VITE_API_URL=http://localhost:8080
FRONTEND_PORT=5173

# ---------- Proxy nginx (apenas hom/prod) ----------
PROXY_HTTP_PORT=80
PROXY_HTTPS_PORT=443
