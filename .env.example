# Variáveis de ambiente do CarWash — copie para .env (e por ambiente: .env.dev, .env.hom, .env.prod)
# NUNCA versionar arquivos .env reais (DAT §8.3 — segredos fora do código)

# ---------- PostgreSQL ----------
POSTGRES_DB=carwash
POSTGRES_USER=carwash_owner
POSTGRES_PASSWORD=
POSTGRES_PORT=5432

# ---------- Backend (.NET) ----------
ASPNETCORE_ENVIRONMENT=Development
BACKEND_PORT=8080

# Segredo do JWT — gere com: openssl rand -base64 64
JWT_SECRET=trocar-em-cada-ambiente-com-pelo-menos-64-caracteres-aleatorios
JWT_ISSUER=carwash
JWT_AUDIENCE=carwash-web

# ---------- Frontend (Vite) ----------
# Em dev aponta para o backend direto; em hom/prod fica /api (passa pelo proxy)
VITE_API_URL=http://localhost:8080
FRONTEND_PORT=5173

# ---------- Proxy nginx (apenas hom/prod) ----------
PROXY_HTTP_PORT=80
PROXY_HTTPS_PORT=443
