# syntax=docker/dockerfile:1.7
# Frontend Vite — desenvolvimento com HMR
# Usado APENAS pelo docker-compose.dev.yml (bind mount + vite --host)

ARG NODE_VERSION=20

FROM node:${NODE_VERSION}-alpine
WORKDIR /app

# Polling para HMR funcionar com bind mount em WSL/macOS
ENV CHOKIDAR_USEPOLLING=true \
    WATCHPACK_POLLING=true \
    HOST=0.0.0.0

EXPOSE 5173

# node_modules pode ser montado como volume nomeado para evitar conflito
# entre host e container (especialmente Linux x Alpine). O CMD garante install
# se a pasta estiver vazia. --force resolve bindings nativos (rolldown) para musl.
CMD ["sh", "-c", "if [ ! -f node_modules/.installed ] || [ package-lock.json -nt node_modules/.installed ]; then npm install --no-audit --no-fund --force && touch node_modules/.installed; fi && npm run dev -- --host 0.0.0.0"]
